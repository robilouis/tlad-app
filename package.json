{
  "name": "tlad-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync": "tsx scripts/build-content.ts",
    "icons": "tsx scripts/make-icons.ts",
    "validate:evals": "tsx scripts/build-content.ts --evals-only",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "tsx --test shared/*.test.ts",
    "typecheck:worker": "tsc -p worker/tsconfig.json",
    "worker:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply tlad-progress --remote"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@fontsource/space-grotesk": "^5.1.0",
    "d3-force": "^3.0.0",
    "jose": "^5.9.6",
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@types/d3-force": "^3.0.10",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "github-slugger": "^2.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^6.0.3",
    "wrangler": "^4.112.0",
    "zod": "^3.23.8"
  }
}
